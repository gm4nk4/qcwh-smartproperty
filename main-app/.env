# OAUTH2 短信客户端信息
VITE_OAUTH2_MOBILE_CLIENT='app:app'

# 是否开启前端验证码
VITE_VERIFY_ENABLE = true

# 前端加密密钥
VITE_PWD_ENC_KEY='xINC5ZFr35lBcvYv'

# 是否开启websocket 消息接受,
VITE_WEBSOCKET_ENABLE = false

# websocket 地址,
