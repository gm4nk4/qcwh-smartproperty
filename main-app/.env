# 是否是微服务架构（重要）
VITE_IS_MICRO = true

# 前端访问前缀
VITE_PUBLIC_PATH = /

# 后端请求前缀
# 子应用独立运行 -> 使用 /api
# 子应用在主应用中运行 -> 使用 /parking-api
VITE_API_URL = /api
VITE_API_URL_QIANKUN = /parking-api

# OAUTH2 密码模式客户端信息
